# TreeOS Land Configuration
#
# Run `npm start` and the setup wizard generates this on first boot.
# Or create manually. Only four keys are required:

# ── Required (kernel, needed before boot) ──
LAND_DOMAIN=localhost
PORT=3000
MONGODB_URI=mongodb://localhost:27017/land
# JWT_SECRET=          (auto-generated by setup wizard)
# CUSTOM_LLM_API_SECRET_KEY=  (auto-generated by setup wizard)

# ── Seeded into .config node on first boot ──
LAND_NAME=My Land

# ── Extension settings (read from .env by their extensions) ──
REQUIRE_EMAIL=false
ENABLE_FRONTEND_HTML=true
HORIZON_URL=https://horizon.treeos.ai

# ── Extension env vars ──
# Extensions declare their own env vars in manifest.js (provides.env).
# The loader auto-generates missing vars or skips the extension.
# Check each extension's manifest for what it needs.

# ── Runtime config ──
# Runtime settings are stored in the .config system node after first boot.
# Manage with: treeos config set <key> <value>
# See SEED.md for all kernel config keys.
#
# Change extension profiles: node boot.js --setup
# Or edit extensions/.treeos-profile (one name per line) and restart.
