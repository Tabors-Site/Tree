# ===========================================
# Tree Land Node Configuration
# ===========================================

# Land Identity
# The public domain of this land node.
# Set this to your domain. Defaults to localhost for local development.
LAND_DOMAIN=localhost
LAND_NAME=My Land

# Port for the land server
PORT=80

# MongoDB connection string
# If using docker-compose, this is set automatically.
MONGODB_URI=mongodb://localhost:27017/tree

# JWT secret for user authentication
JWT_SECRET=change-this-to-a-random-string

# ===========================================
# Canopy Network (optional, for federation)
# ===========================================

# Directory service URL for network discovery.
# Leave empty to run in standalone mode.
DIRECTORY_URL=

# If this land has moved to a new domain, set the redirect here.
# Peers will auto-update during heartbeat.
LAND_REDIRECT_TO=

# Default profile tier for new users on this land.
# Self-hosted lands typically use "god" for unlimited energy.
LAND_DEFAULT_TIER=god

# ===========================================
# Site (optional frontend)
# ===========================================
TREE_FRONTEND_DOMAIN=http://localhost:3000

# creators website
ROOT_FRONTEND_DOMAIN=https://tabors.site
FRONTEND_PORT=3000

# for sign in connection from frontend

VITE_TREE_API_URL=https://localhost:3000/api/v1

# Enable server-rendered HTML pages (user profiles, node views, etc.)
# Set to "true" to serve HTML pages from the land server.
# Set to anything else or leave unset to return JSON only.
ENABLE_FRONTEND_HTML=true

# ===========================================
# LLM Configuration
# ===========================================


# Encryption key for stored custom LLM connections
CUSTOM_LLM_API_SECRET_KEY=change-this-to-a-random-string

# ===========================================
# Email to send account authentication for account signups
# ===========================================
EMAIL_USER=
EMAIL_PASS=

# ===========================================
# Stripe (optional, for payments)
# ===========================================
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ===========================================
# Push Notifications (optional)
# ===========================================
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=

# ===========================================
# Solana (optional, for on-chain features)
# ===========================================
# NODE_WALLET_MASTER_KEY=fjdoijfodsifjodsaijfoaj4jo4i3foi3f43oifn3o34nfo43info3i438
# SOLANA_RPC_URL=
# JUP_API_KEY=
