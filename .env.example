# TreeOS Land Configuration
#
# Run `npm land` and the setup wizard generates this for you.
# Or create manually. Only these are required:

# ── Required ──
LAND_DOMAIN=localhost
LAND_NAME=My Land
PORT=3000
MONGODB_URI=mongodb://localhost:27017/tree

# Auto-generated by setup wizard if left blank:
# JWT_SECRET=
# CUSTOM_LLM_API_SECRET_KEY=

# ── Optional ──

# Enable server-rendered HTML pages (dashboard, chat, node views)
# ENABLE_FRONTEND_HTML=true

# Canopy directory for land discovery and extension registry
# DIRECTORY_URL=https://dir.treeos.ai

# Email (for registration verification and password reset)
# EMAIL_USER=you@example.com
# EMAIL_PASS=app-specific-password

# Push notifications (for web push gateway channel)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:you@example.com

# ── Extension env vars ──
# Declared in each extension's manifest.js under provides.env.
# Missing required vars cause the extension to be skipped on boot.

# Stripe (billing extension)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Solana (solana extension)
# NODE_WALLET_MASTER_KEY=your-32-byte-hex-key
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# JUP_API_KEY=

# ── Vite (only needed if building site/ frontend) ──
# VITE_LAND_URL=http://localhost:3000
# VITE_LAND_NAME=My Land
# VITE_TREE_API_URL=http://localhost:3000/api/v1

# ── Runtime config ──
# LAND_NAME, LAND_DEFAULT_TIER, and other runtime settings are stored
# in the .config system node. Manage with: treeos config set <key> <value>
# See the guide for all 11 kernel config keys.
