# Tree Land Node Configuration
#
# You don't need to create this file manually.
# Run `npm start` and the setup wizard will generate it for you.
#
# If you prefer to create it yourself, only these are required:

LAND_DOMAIN=localhost
PORT=3000
MONGODB_URI=mongodb://localhost:27017/tree

# These are auto-generated by the setup wizard if left blank:
# JWT_SECRET=
# CUSTOM_LLM_API_SECRET_KEY=

# Runtime settings (LAND_NAME, LAND_DEFAULT_TIER, ENABLE_FRONTEND_HTML,
# DIRECTORY_URL) are stored in the .config system node, not here.
# Manage them with: treeos config set <key> <value>

# Optional (uncomment if needed) (Email account to send emails out to new accounts if you choose to enable EMAIL registration):
# EMAIL_USER=
# EMAIL_PASS=

# Push notifications (only if need WEBAPP gateway channel for outputs):
# can stil use discord/telegram input/output without
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:you@example.com

# Extension env vars (Stripe, Solana, etc.) are declared in each
# extension's manifest.js under provides.env. If a required var is
# missing, the extension is skipped with a clear message on boot.
# See land/extensions/EXTENSION_FORMAT.md for details.
