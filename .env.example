# TreeOS Land Configuration
#
# Run `npm start` and the setup wizard generates this on first boot.
# Or create manually. Only these are required:

# ── Required (kernel, needed before boot) ──
LAND_DOMAIN=localhost
PORT=3000
MONGODB_URI=mongodb://localhost:27017/land

# Auto-generated by setup wizard if left blank:
# JWT_SECRET=
# CUSTOM_LLM_API_SECRET_KEY=



# ── Extension env vars ──
# Each extension declares required env vars in manifest.js under provides.env.
# Missing required vars cause the extension to be skipped on boot.

# html-rendering
# ENABLE_FRONTEND_HTML=true

# canopy
# HORIZON_URL=https://horizon.treeos.ai

# email
# EMAIL_USER=you@example.com
# EMAIL_PASS=app-specific-password

# push notifications
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:you@example.com

# billing
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# solana
# NODE_WALLET_MASTER_KEY=your-32-byte-hex-key
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# JUP_API_KEY=

# ── Vite (build-time only, not used by the land server) ──
# VITE_LAND_URL=http://localhost:3000
# VITE_LAND_NAME=My Land
# VITE_TREE_API_URL=http://localhost:3000/api/v1
# VITE_HORIZON=https://horizon.treeos.ai
# ── Runtime config ──
# LAND_NAME and other runtime settings are stored in the .config system node.
# Manage with: treeos config set <key> <value>
# See SEED.md for all kernel config keys.
