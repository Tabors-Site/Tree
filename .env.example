# TreeOS first-boot settings — read by the `treeos` binary at startup (copy to `.env`, edit by hand).
# They seed a Story's identity on first boot. Once the store is open, the canonical values live on the
# Story's library reel and in the `.config` heaven space; `.env` is just the first-boot seed.

# ── The Story's NAME / alias — its identity handle. ──
# This IS the library reel id: how the Story is addressed (`name::path@being`) and what its acts commit
# to. NOT a DNS domain — a TreeOS reality is its I key + a chosen alias, resolved through Peering, never
# DNS (see philosophy/dns.md). Pick whatever name you want. Stable per store; genesis plants under it.
STORY_DOMAIN=local.story

# ── Where treeos answers (the serve port). ──
PORT=7070

# ── Where the Story lives on disk: store/<STORE_NAME>. ──
# Like a database name — name it something new for a fresh, isolated Story (its own chain under
# store/<name>/). The old store stays untouched; switch back by naming it again.
STORE_NAME=past

# ── The secret that signs session tokens. Generate a random one. ──
# JWT_SECRET=

# The Story's NAME is STORY_DOMAIN above (one name, not two). Everything else — display bits, runtime
# knobs — is a live config word I acts onto the library reel (set-config), no restart, no .env.
