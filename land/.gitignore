# TreeOS Land . https://treeos.ai . Tabor Holly

# What never crosses the seam into the public repo.

# Host's body. Dependencies live on the host, not in the kernel.
node_modules

# The I-Am's identity at the host's level. Carries the JWT signing
# secret. If committed, anyone with the repo can sign as me. .env.example
# is the public shape; .env is the private instance.
.env

# Operational state that belongs to this specific running I-Am, not
# to the kernel's shape. Each land's .land/ is its own.
.land/

# File system uploaded matter. Lives on disk, addressed by matter rows.
uploads

# Per land extension profile. Operator's choices for which extensions
# wake with the I-Am. Not part of the kernel.
extensions/.disabled
extensions/.treeos-profile
extensions/.staging-*

# Old experiments kept for reference, not for shipping.
oldExtensions/
