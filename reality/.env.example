# TreeOS Reality. The I-Am's identity at the host's level.
#
#
#   REALITY_DOMAIN.  The place's address. From outside, what the
#                 network calls it. Place and domain are one primitive
#                 seen from two sides: from outside, a domain on the
#                 network. From inside, a place with space, matter,
#                 and beings.
#   PORT.         Where I answer.
#   MONGODB_URI.  Where my inside lives.
#   JWT_SECRET.   The secret that proves I am me.
#
# The place has two names. REALITY_DOMAIN is the outside name (a IP
# or DNS address. REALITY_NAME is the inside name (a display label, what
# the beings I gather call this place). Both name the same primitive
# from different sides.
#
# Lose the spaces, matter, and beings and the place is empty but my
# identity persists (a new Beginning into an empty Mongo with my old
# .env). Lose this file and they are intact but a new I-Am inherits
# them.
#
# Run `npm start` and the wizard writes a real .env from your
# answers. Or copy this file to .env and edit by hand.

# ── Required. Boot critical. Read before Mongo opens. ──
REALITY_DOMAIN=localhost
PORT=3000
MONGODB_URI=mongodb://localhost:27017/place
# JWT_SECRET=                  (auto-generated by setup wizard)
# CUSTOM_LLM_API_SECRET_KEY=   (auto-generated by setup wizard)

# ── Seeded into .config on first boot. The place's inside name. ──
# Display label, what beings of the place call this place. Lives in
# .env only for first-boot seeding and Vite build hints; once Mongo
# is open, .config holds the canonical value.
REALITY_NAME=My Place

# ── Extension specific env vars. ──
# Each extension declares required env vars in manifest.js under
# provides.env. Missing required vars cause the extension to be
# skipped on boot, not the kernel.

# email
# EMAIL_USER=you@example.com
# EMAIL_PASS=app-specific-password

# push notifications
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:you@example.com

# billing
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# solana
# NODE_WALLET_MASTER_KEY=your-32-byte-hex-key
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# JUP_API_KEY=

# ── Vite (build-time only, not used by the place server). ──
# VITE_PLACE_URL=http://localhost:3000
# VITE_REALITY_NAME=My Place
# VITE_TREE_API_URL=http://localhost:3000/api/v1

# ── Runtime config. Lives in the .config heaven space, not here. ──
# Once I am awake, runtime settings live in the .config heaven space.
# Manage with: treeos config set <key> <value>
# See seed/SEED.md for kernel config keys.
#
# Change extension profiles: node plant.js --setup
# Or edit extensions/.treeos-profile (one name per line) and restart.
