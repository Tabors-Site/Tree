{
  "meta": {
    "bundleVersion": "1.0",
    "sourceReality": "roots",
    "sourceBranch": "0",
    "sourceScopeName": "catalog",
    "sourceScopeSpaceId": "catalog-root",
    "createdAt": "2026-06-12T00:00:00.000Z",
    "operatorBeingId": null
  },
  "manifest": {
    "extensions": ["roots"],
    "roles": ["roots:registrar"]
  },
  "parameters": [
    {
      "name": "spaceName",
      "type": "string",
      "default": "roots",
      "description": "Name of the catalog space."
    },
    {
      "name": "beingName",
      "type": "string",
      "default": "registrar",
      "description": "Name of the registrar being that writes the catalog."
    }
  ],
  "content": {
    "spaces": [
      {
        "sourceId": "catalog-root",
        "name": "$spaceName",
        "type": "domain",
        "parent": { "__ref": "insertion-point" },
        "owner": { "__ref": "being", "id": "registrar-being" },
        "rootOwner": { "__ref": "graft-initiator" },
        "contributors": [],
        "size": null,
        "coord": null,
        "qualities": { "roots": { "catalog": true } }
      }
    ],
    "beings": [
      {
        "sourceId": "registrar-being",
        "name": "$beingName",
        "defaultRole": "roots:registrar",
        "parentBeingId": { "__ref": "graft-initiator" },
        "homeSpace": { "__ref": "space", "id": "catalog-root" },
        "position": { "__ref": "space", "id": "catalog-root" },
        "coord": null,
        "qualities": {}
      }
    ],
    "matter": []
  }
}
